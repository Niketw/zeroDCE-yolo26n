# Discord Webhook Configuration
# Replace these values with your actual webhook URL and User ID
DISCORD_WEBHOOK_URL="https://discord.com/api/webhooks/your_webhook_id/your_webhook_token"

# To get your Discord User ID: Enable Developer Mode in Discord settings, 
# then right-click your profile and select "Copy User ID"
# Format should be: <@YOUR_ID_HERE>
DISCORD_USER_ID="<@123456789012345678>"
