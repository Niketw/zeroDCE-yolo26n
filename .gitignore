# =========================
# Datasets & Downloads
# =========================
# Ignore the massive BDD100K dataset and extracted files
dataset/
datasets/
# Ignore archive files to save space
*.zip
*.tar
*.tar.gz
*.rar
# Ignore raw JSON label files and generated YAML
*.json
bdd_vehicles.yaml
# Ignore kaggle cache/configs if generated locally
.kaggle/
.kaggle_cache/
kagglehub_cache/

# =========================
# YOLO / Ultralytics
# =========================
# Ignore training runs, logs, and generated weights
runs/
bdd_tuning/
# Ignore pre-trained and fine-tuned model weights
*.pt
*.onnx
*.engine
*.tflite
*.pb
*.torchscript
# Ignore experiment tracking logs (if you end up using them)
wandb/
clearml/

# =========================
# Python & Virtual Environments
# =========================
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
dist/
*.egg-info/
.eggs/
*.egg
# Environments
venv/
env/
.venv/
ENV/
.env

